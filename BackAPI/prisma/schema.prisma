// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model RefreshToken {
  id             Int         @id @default(autoincrement())
  token          String      @unique
  dateCreation   DateTime    @default(now())
  dateExpiration DateTime    @default(dbgenerated("NOW() + interval '7 days'"))
  utilisateur    Utilisateur @relation(fields: [utilisateurId], references: [id])
  utilisateurId  Int

  @@unique([utilisateurId])
}

model Utilisateur {
  id               Int               @id @default(autoincrement())
  nom              String
  prenom           String
  email            String            @unique
  motDePasse       String
  role             String
  dateCreation     DateTime          @default(now())
  dateModification DateTime          @default(now())
  status           Boolean
  informations     Information[]
  activiteDetente  ActiviteDetente[]
  favoris          Favori[]
  refreshToken     RefreshToken?
}

model Information {
  id               Int         @id @default(autoincrement())
  titre            String
  description      String
  texte            String
  image            String?
  categorie        String
  status           Boolean
  dateCreation     DateTime    @default(now())
  dateModification DateTime    @default(now())
  author           Utilisateur @relation(fields: [authorId], references: [id])
  authorId         Int
}

model ActiviteDetente {
  id               Int         @id @default(autoincrement())
  titre            String
  description      String
  duree            Int
  difficulte       Int
  image            String?
  type             String
  status           Boolean
  dateCreation     DateTime    @default(now())
  dateModification DateTime    @default(now())
  author           Utilisateur @relation(fields: [authorId], references: [id])
  authorId         Int
  favoris          Favori[]
}

model Favori {
  id                Int             @id @default(autoincrement())
  utilisateur       Utilisateur     @relation(fields: [utilisateurId], references: [id])
  utilisateurId     Int
  activiteDetente   ActiviteDetente @relation(fields: [activiteDetenteId], references: [id])
  activiteDetenteId Int

  @@unique([utilisateurId, activiteDetenteId])
}
