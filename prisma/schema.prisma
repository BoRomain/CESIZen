generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Utilisateur {
  id              Int               @id @default(autoincrement())
  nom             String
  prenom          String
  email           String            @unique
  motDePasse      String
  role            String
  dateCreation    DateTime
  status          Boolean
  informations    Information[]
  activiteDetente ActiviteDetente[]
  favoris         Favori[]
}

model Information {
  id           Int         @id @default(autoincrement())
  titre        String
  description  String
  texte        String
  image        String
  categorie    String
  status       Boolean
  dateCreation DateTime
  author       Utilisateur @relation(fields: [authorId], references: [id])
  authorId     Int
}

model ActiviteDetente {
  id           Int         @id @default(autoincrement())
  titre        String
  description  String
  duree        Int
  difficulte   Int
  image        String
  status       Boolean
  dateCreation DateTime
  author       Utilisateur @relation(fields: [authorId], references: [id])
  authorId     Int
  favoris      Favori[]
}

model Favori {
  id                Int             @id @default(autoincrement())
  utilisateur       Utilisateur     @relation(fields: [utilisateurId], references: [id])
  utilisateurId     Int
  activiteDetente   ActiviteDetente @relation(fields: [activiteDetenteId], references: [id])
  activiteDetenteId Int

  @@unique([utilisateurId, activiteDetenteId])
}
