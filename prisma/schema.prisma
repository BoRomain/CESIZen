// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Utilisateur {
  id              Int               @id @default(autoincrement())
  nom             String
  prenom          String
  email           String            @unique
  motDePasse      String
  role            String
  dateCreation    DateTime
  status          Boolean
  informations    Information[]
  activiteDetente ActiviteDetente[]
}

model Information {
  id           Int         @id @default(autoincrement())
  nom          String
  prenom       String
  email        String      @unique
  motDePasse   String
  role         String
  dateCreation DateTime
  status       Boolean
  author       Utilisateur @relation(fields: [authorId], references: [id])
  authorId     Int
}

model ActiviteDetente {
  id           Int         @id @default(autoincrement())
  nom          String
  description  String
  dateCreation DateTime
  status       Boolean
  author       Utilisateur @relation(fields: [authorId], references: [id])
  authorId     Int
}
